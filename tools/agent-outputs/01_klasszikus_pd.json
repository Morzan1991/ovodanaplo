  {
    "tipus": "vers",
    "cim": "Szeptember végén",
    "szerzo": "Petőfi Sándor",
    "forras": "MEK.OSZK.HU — Petőfi Sándor összes költeményei (1847)",
    "korcsoport": "nagy",
    "temak": ["ősz", "szerelem", "évszakok"],
    "szoveg": "Még nyílnak a völgyben a kerti virágok,\nMég zöldel a nyárfa az ablak előtt,\nDe látod amottan a téli világot?\nMár hó takará el a bérci tetőt.\n\n— Petőfi Sándor (részlet)"
  },
  {
    "tipus": "vers",
    "cim": "Nemzeti dal",
    "szerzo": "Petőfi Sándor",
    "forras": "MEK.OSZK.HU — Petőfi Sándor összes költeményei (1848)",
    "korcsoport": "nagy",
    "temak": ["haza", "szabadság", "ünnep", "marcius_15"],
    "szoveg": "Talpra magyar, hí a haza!\nItt az idő, most vagy soha!\nRabok legyünk vagy szabadok?\nEz a kérdés, válasszatok! —\nA magyarok istenére\nEsküszünk,\nEsküszünk, hogy rabok tovább\nNem leszünk!"
  },
