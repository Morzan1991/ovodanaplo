    "korcsoport": "nagy",
    "temak": ["madarak", "humor", "tanulság"]
  },
  {
    "tipus": "vers",
    "cim": "Szondi két apródja",
    "szerzo": "Arany János",
    "forras": "MEK.OSZK.HU — Arany János balladái (1856)",
    "korcsoport": "nagy",
    "temak": ["történelem", "hűség"]
  },
  {
    "tipus": "vers",
    "cim": "Mátyás anyja",
    "szerzo": "Arany János",
    "forras": "MEK.OSZK.HU — Arany János balladái (1854)",
    "korcsoport": "nagy",
    "temak": ["anya", "fiú", "várakozás"],
    "szoveg": "Szilágyi\nErzsébet\nLevelét megírta;\nSzerelmes\nKönnyével\nÁzott sűrü sorja.\n\n— Arany János (részlet)"
  },
  {
    "tipus": "vers",
    "cim": "Rege a csodaszarvasról",
    "szerzo": "Arany János",
    "forras": "MEK.OSZK.HU — Arany János: Buda halála (1864)",
    "korcsoport": "nagy",
    "temak": ["legenda", "monda", "vadászat"],
    "szoveg": "Száll a madár, ágról ágra,\nSzáll az ének, szájról szájra;\nFű kizöldűl ó sirhanton,\nBajnok ébred hősi lanton.\n\n— Arany János (részlet)"
  },
  {
    "tipus": "vers",
    "cim": "Szózat",
    "szerzo": "Vörösmarty Mihály",
    "forras": "MEK.OSZK.HU — Vörösmarty Mihály összes költeményei (1836)",
    "korcsoport": "nagy",
    "temak": ["haza", "hazaszeretet"],
    "szoveg": "Hazádnak rendületlenűl\nLégy híve, oh magyar;\nBölcsőd az s majdan sírod is,\nMely ápol s eltakar.\n\n— Vörösmarty Mihály (részlet)"
  },
